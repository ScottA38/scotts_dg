		{"id":"235c98ccbd2f8b25","x":350,"y":-620,"width":250,"height":85,"type":"text","text":"MU Plugin directory can be altered via `WPMU_PLUGIN_DIR` ENV var."},
		{"id":"e9b0529f39136f6b","x":-13,"y":-502,"width":250,"height":115,"type":"text","text":"Wordpress mechanisms load plugin files via alpabetical selection ( based upon file name?? )"},
		{"id":"45f3453d76e8b917","x":680,"y":-480,"width":250,"height":113,"type":"text","text":"WP does not run plugin activation hooks for folders/files found in the `mu-plugins` dir"},
		{"id":"7858eded256d538b","x":495,"y":-268,"width":250,"height":85,"type":"text","text":"MU Plugins do not notify r.e updates in typical WP-Admin screen"},
		{"id":"3b31bdbcc2bc72e9","x":860,"y":-296,"width":250,"height":226,"type":"text","text":"> \"The _mu-plugins_ directory was originally implemented by WPMU (Multi-User) to offer site admins an easy way to activate plugins by default on all blogs in the farm\""}
